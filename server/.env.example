# BRIX Server Environment Variables
PORT=3100
BRIX_DOMAIN=brix.app
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Spark SDK (server wallet)
SPARK_MNEMONIC=
SPARK_NETWORK=mainnet

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# SendGrid (email verification - alternative)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@brix.app

# SMTP (email verification - ProtonMail Bridge or other)
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Database
DB_PATH=./brix.db
