# BRIX Server Environment Variables
PORT=3100
BRIX_DOMAIN=brix.app
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# Spark SDK (server wallet)
SPARK_MNEMONIC=
SPARK_NETWORK=mainnet

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# SendGrid (email verification - alternative)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@brix.app

# SMTP (email verification - ProtonMail Bridge or other)
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Database
DB_PATH=./brix.db

# PII Encryption (AES-256-GCM for phone/email at rest)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BRIX_ENCRYPTION_KEY=

# Fee System
BRIX_FEE_ENABLED=false
BRIX_FEE_RATE=0.01
BRIX_MIN_FEE_SATS=1
BRIX_ADMIN_KEY=

# Wallet Provider (for fee collection)
WALLET_PROVIDER=mock
WALLET_MODE=regular
WALLET_URL=
LNBITS_INVOICE_KEY=
LNBITS_ADMIN_KEY=
